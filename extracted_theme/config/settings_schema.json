[
  {
    "name": "theme_info",
    "theme_name": "Custom Gold Jewelry Theme",
    "theme_version": "1.0.0",
    "theme_author": "Your Brand",
    "theme_documentation_url": "https://help.yourbrand.com",
    "theme_support_url": "https://support.yourbrand.com"
  },
  {
    "name": "Brand Colors - Luxury Gold System",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary color (Dark)",
        "default": "#1C1917",
        "info": "Main brand color for headings and important elements"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary color (Medium Dark)",
        "default": "#44403C",
        "info": "Secondary brand color for backgrounds and borders"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color (Gold)",
        "default": "#CA8A04",
        "info": "Gold accent for buttons, links, and highlights - perfect for jewelry"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background color",
        "default": "#FAFAF9",
        "info": "Main background color for the site"
      },
      {
        "type": "color",
        "id": "color_background_alt",
        "label": "Alternative background",
        "default": "#F5F5F4",
        "info": "Used for cards and sections with different background"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text color (Dark)",
        "default": "#0C0A09",
        "info": "Main text color for body content"
      },
      {
        "type": "color",
        "id": "color_text_light",
        "label": "Light text color",
        "default": "#78716C",
        "info": "Used for secondary text and descriptions"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border color",
        "default": "#D6D3D1",
        "info": "Color for borders and dividers"
      }
    ]
  },
  {
    "name": "Typography - Luxury Font Pairing",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font (Cormorant recommended)",
        "default": "cormorant_n4",
        "info": "Serif font for luxury feel - Cormorant is perfect for jewelry brands"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font (Montserrat recommended)",
        "default": "montserrat_n4",
        "info": "Clean sans-serif for readability - Montserrat pairs well with Cormorant"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Base font size",
        "default": 16,
        "info": "Main text size for body content"
      },
      {
        "type": "range",
        "id": "font_scale_ratio",
        "min": 1.1,
        "max": 1.4,
        "step": 0.05,
        "label": "Font scale ratio",
        "default": 1.25,
        "info": "Ratio for heading sizes - higher = more dramatic hierarchy"
      },
      {
        "type": "header",
        "content": "Advanced Typography"
      },
      {
        "type": "checkbox",
        "id": "enable_custom_fonts",
        "label": "Enable custom Google Fonts",
        "default": true,
        "info": "Load Cormorant and Montserrat from Google Fonts"
      },
      {
        "type": "text",
        "id": "custom_font_url",
        "label": "Custom font URL",
        "default": "https://fonts.googleapis.com/css2?family=Cormorant:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap",
        "info": "URL for custom font loading"
      }
    ]
  },
  {
    "name": "Brand Identity & Logo",
    "settings": [
      {
        "type": "header",
        "content": "Logo Configuration"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Main logo image",
        "info": "Upload your brand logo. Recommended: PNG with transparent background, min 300px width"
      },
      {
        "type": "image_picker",
        "id": "logo_light",
        "label": "Light version logo (optional)",
        "info": "For use on dark backgrounds. Leave empty to use main logo"
      },
      {
        "type": "image_picker",
        "id": "logo_dark",
        "label": "Dark version logo (optional)",
        "info": "For use on light backgrounds. Leave empty to use main logo"
      },
      {
        "type": "image_picker",
        "id": "logo_footer",
        "label": "Footer logo (optional)",
        "info": "Different logo for footer. Leave empty to use main logo"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32x32px PNG for browser tabs"
      },
      {
        "type": "header",
        "content": "Logo Sizing & Display"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "min": 80,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Header logo max width",
        "default": 200,
        "info": "Maximum width of logo in header"
      },
      {
        "type": "range",
        "id": "logo_max_height",
        "min": 30,
        "max": 100,
        "step": 5,
        "unit": "px",
        "label": "Header logo max height",
        "default": 60,
        "info": "Maximum height of logo in header"
      },
      {
        "type": "range",
        "id": "footer_logo_width",
        "min": 60,
        "max": 200,
        "step": 10,
        "unit": "px",
        "label": "Footer logo width",
        "default": 120,
        "info": "Width of logo in footer"
      },
      {
        "type": "checkbox",
        "id": "logo_center_header",
        "label": "Center logo in header",
        "default": false,
        "info": "Center the logo instead of left-aligning"
      },
      {
        "type": "checkbox",
        "id": "logo_show_text",
        "label": "Show text fallback if no logo",
        "default": true,
        "info": "Show store name if no logo is uploaded"
      },
      {
        "type": "color",
        "id": "logo_text_color",
        "label": "Logo text color",
        "default": "#1C1917",
        "info": "Color for text fallback when no logo"
      },
      {
        "type": "header",
        "content": "Logo Effects & Animation"
      },
      {
        "type": "checkbox",
        "id": "logo_hover_effect",
        "label": "Enable logo hover effect",
        "default": true,
        "info": "Add subtle animation on logo hover"
      },
      {
        "type": "checkbox",
        "id": "logo_reduce_motion",
        "label": "Respect reduced motion preference",
        "default": true,
        "info": "Disable animations for users who prefer reduced motion"
      },
      {
        "type": "select",
        "id": "logo_hover_animation",
        "label": "Logo hover animation",
        "options": [
          {
            "value": "scale",
            "label": "Scale up"
          },
          {
            "value": "fade",
            "label": "Fade"
          },
          {
            "value": "none",
            "label": "None"
          }
        ],
        "default": "scale",
        "info": "Animation type when hovering over logo"
      },
      {
        "type": "link_list",
        "id": "main_menu",
        "label": "Main menu",
        "default": "main-menu"
      },
      {
        "type": "checkbox",
        "id": "show_search",
        "label": "Show search bar",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_cart_icon",
        "label": "Show cart icon",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Enable sticky header",
        "default": true
      }
    ]
  },

{%- comment -%}
  Brand logo snippet with multiple variations
  Based on Anthropic Frontend Design System
  Version: 2.0.0
{%- endcomment -%}

{%- liquid
  # Accept parameters
  assign logo_type = logo_type | default: 'header'
  assign logo_size = logo_size | default: 'medium'
  assign show_text = show_text | default: false
  assign text_position = text_position | default: 'below'
  assign custom_class = custom_class | default: ''

  # Determine which logo to use based on type
  assign logo_to_use = section.settings.logo
  assign logo_max_width = section.settings.logo_max_width | default: 200
  
  if logo_type == 'footer'
    if section.settings.logo_footer != blank
      assign logo_to_use = section.settings.logo_footer
    endif
    assign logo_max_width = section.settings.footer_logo_width | default: 120
  elsif logo_type == 'checkout'
    if section.settings.checkout_logo != blank
      assign logo_to_use = section.settings.checkout_logo
    endif
    assign logo_max_width = 150
  endif

  # Size adjustments
  if logo_size == 'small'
    assign logo_max_width = logo_max_width | times: 0.7 | round
  elsif logo_size == 'large'
    assign logo_max_width = logo_max_width | times: 1.3 | round
  elsif logo_size == 'xlarge'
    assign logo_max_width = logo_max_width | times: 1.6 | round
  endif

  # Build logo container classes
  assign container_classes = 'brand-logo brand-logo--' | append: logo_type
  assign container_classes = container_classes | append: ' brand-logo--' | append: logo_size
  
  if custom_class != blank
    assign container_classes = container_classes | append: ' ' | append: custom_class
  endif

  # Build logo image classes
  assign image_classes = 'brand-logo__image'
  if logo_type == 'footer'
    assign image_classes = image_classes | append: ' brand-logo__image--footer'
  endif
-%}

<div class="{{ container_classes }}"
     data-brand-logo
     data-logo-type="{{ logo_type }}"
     data-logo-size="{{ logo_size }}"
     style="--logo-width: {{ logo_max_width }}px;">
  
  {%- if logo_to_use != blank -%}
    {%- comment -%}Display logo image{%- endcomment -%}
    <a href="{{ routes.root_url }}" 
       class="brand-logo__link" 
       aria-label="{{ shop.name }} - {{ logo_type | capitalize }} logo">
      
      <img src="{{ logo_to_use | img_url: 'master' }}"
           class="{{ image_classes }}"
           alt="{{ shop.name }}"
           width="{{ logo_to_use.width }}"
           height="{{ logo_to_use.height }}"
           loading="lazy"
           style="max-width: {{ logo_max_width }}px;"
           data-brand-logo-image>
    </a>
  
  {%- elsif show_text -%}
    {%- comment -%}Display text version{%- endcomment -%}
    <a href="{{ routes.root_url }}" 
       class="brand-logo__text-link" 
       aria-label="{{ shop.name }}">
      
      <div class="brand-logo__text-container brand-logo__text-container--{{ text_position }}">
        <span class="brand-logo__text-primary">
          {{ shop.name }}
        </span>
        
        {%- if shop.description != blank -%}
          <span class="brand-logo__text-secondary">
            {{ shop.description | truncate: 30 }}
          </span>
        {%- endif -%}
      </div>
    </a>
  
  {%- else -%}
    {%- comment -%}Display placeholder{%- endcomment -%}
    <a href="{{ routes.root_url }}" 
       class="brand-logo__placeholder-link" 
       aria-label="{{ shop.name }}">
      
      <div class="brand-logo__placeholder">
        <svg class="brand-logo__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 22V12h6v10" />
        </svg>
        <span class="brand-logo__placeholder-text">{{ shop.name | slice: 0, 2 | upcase }}</span>
      </div>
    </a>
  
  {%- endif -%}

  {%- if show_text and text_position == 'right' -%}
    {%- comment -%}Text on the right side{%- endcomment -%}
    <div class="brand-logo__side-text">
      <span class="brand-logo__side-text-primary">{{ shop.name }}</span>
      {%- if shop.description != blank -%}
        <span class="brand-logo__side-text-secondary">{{ shop.description | truncate: 25 }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{%- style -%}
  /* Brand logo container */
  .brand-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all var(--transition);
  }

  /* Logo type variations */
  .brand-logo--header {
    padding: 8px 0;
  }

  .brand-logo--footer {
    opacity: 0.9;
    margin-bottom: 16px;
  }

  .brand-logo--footer:hover {
    opacity: 1;
  }

  .brand-logo--checkout {
    margin: 0 auto;
    justify-content: center;
  }

  /* Logo size variations */
  .brand-logo--small {
    --logo-width: 120px;
  }

  .brand-logo--medium {
    --logo-width: 200px;
  }

  .brand-logo--large {
    --logo-width: 260px;
  }

  .brand-logo--xlarge {
    --logo-width: 320px;
  }

  /* Logo image styles */
  .brand-logo__image {
    display: block;
    object-fit: contain;
    transition: all var(--transition);
    max-width: var(--logo-width);
    height: auto;
  }

  .brand-logo__link:hover .brand-logo__image {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .brand-logo__image--footer {
    filter: brightness(0.95);
  }

  /* Text logo styles */
  .brand-logo__text-link {
    text-decoration: none;
    color: inherit;
  }

  .brand-logo__text-container {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .brand-logo__text-container--below {
    text-align: center;
  }

  .brand-logo__text-container--right {
    text-align: left;
  }

  .brand-logo__text-primary {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.1;
  }

  .brand-logo__text-secondary {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-light);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Placeholder logo */
  .brand-logo__placeholder-link {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .brand-logo__placeholder {
    width: var(--logo-width);
    height: calc(var(--logo-width) * 0.5);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: white;
    transition: all var(--transition);
  }

  .brand-logo__placeholder:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .brand-logo__placeholder-icon {
    width: 32px;
    height: 32px;
    stroke-width: 1.5;
  }

  .brand-logo__placeholder-text {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  /* Side text for right position */
  .brand-logo__side-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-logo__side-text-primary {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-primary);
  }

  .brand-logo__side-text-secondary {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .brand-logo--large,
    .brand-logo--xlarge {
      --logo-width: 200px;
    }

    .brand-logo__text-primary {
      font-size: 20px;
    }
  }

  @media (max-width: 480px) {
    .brand-logo--large,
    .brand-logo--xlarge {
      --logo-width: 160px;
    }

    .brand-logo__text-primary {
      font-size: 18px;
    }

    .brand-logo__side-text {
      display: none;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .brand-logo,
    .brand-logo__image,
    .brand-logo__placeholder {
      transition: none !important;
    }

    .brand-logo__link:hover .brand-logo__image,
    .brand-logo__placeholder:hover {
      transform: none !important;
    }
  }
{%- endstyle -%}
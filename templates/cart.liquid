{% comment %}Éclat Doréa Cart Page{% endcomment %}
{% section 'announcement-bar' %}
{% section 'header' %}

<main class="main-content page-width">
  <h1 class="cart-title">Your Shopping Cart</h1>
  
  {% if cart.item_count > 0 %}
    <form action="/cart" method="post" novalidate>
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="cart-item__image">
              <img src="{{ item.image | img_url: '200x' }}" alt="{{ item.title | escape }}">
            </div>
            
            <div class="cart-item__details">
              <h3 class="cart-item__title">{{ item.product.title }}</h3>
              <p class="cart-item__variant">{{ item.variant.title }}</p>
              <p class="cart-item__price">{{ item.line_price | money }}</p>
            </div>
            
            <div class="cart-item__quantity">
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0">
            </div>
            
            <div class="cart-item__total">
              {{ item.line_price | money }}
            </div>
          </div>
        {% endfor %}
      </div>
      
      <div class="cart-summary">
        <div class="cart-totals">
          <p class="cart-subtotal">Subtotal: {{ cart.total_price | money }}</p>
          <p class="cart-note">Taxes and shipping calculated at checkout</p>
        </div>
        
        <div class="cart-actions">
          <button type="submit" name="update" class="button button--secondary">Update Cart</button>
          <button type="submit" name="checkout" class="button button--primary">Checkout</button>
        </div>
      </div>
    </form>
  {% else %}
    <div class="cart-empty">
      <p>Your cart is empty</p>
      <a href="{{ routes.collections_url }}" class="button button--primary">Continue Shopping</a>
    </div>
  {% endif %}
</main>

{% section 'footer' %}

<style>
  .cart-title {
    font-family: 'Cormorant', serif;
    font-size: 4rem;
    font-weight: 600;
    margin-bottom: 4rem;
    color: var(--color-primary, #1C1917);
  }

  .cart-item {
    display: grid;
    grid-template-columns: 100px 2fr 100px 100px;
    gap: 2rem;
    align-items: center;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border, #E5E7EB);
  }

  .cart-item__image img {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 0.5rem;
  }

  .cart-item__title {
    font-family: 'Cormorant', serif;
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary, #1C1917);
  }

  .cart-item__variant {
    font-family: 'Montserrat', sans-serif;
    color: #6B7280;
    margin-bottom: 1rem;
  }

  .cart-item__price {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    color: var(--color-accent, #CA8A04);
  }

  .cart-item__quantity input {
    width: 60px;
    padding: 0.5rem;
    border: 1px solid var(--color-border, #E5E7EB);
    border-radius: 0.5rem;
    text-align: center;
  }

  .cart-item__total {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    color: var(--color-accent, #CA8A04);
  }

  .cart-summary {
    margin-top: 4rem;
    padding: 3rem;
    background: var(--color-background-alt, #F5F5F4);
    border-radius: 1rem;
  }

  .cart-subtotal {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.4rem;
    font-weight: 600;
    color: var(--color-primary, #1C1917);
    margin-bottom: 1rem;
  }

  .cart-note {
    font-family: 'Montserrat', sans-serif;
    color: #6B7280;
    margin-bottom: 2rem;
  }

  .cart-actions {
    display: flex;
    gap: 2rem;
  }

  .cart-empty {
    text-align: center;
    padding: 6rem 0;
  }

  .cart-empty p {
    font-family: 'Montserrat', sans-serif;
    font-size: 2rem;
    margin-bottom: 3rem;
    color: var(--color-text, #0C0A09);
  }

  @media (max-width: 768px) {
    .cart-item {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .cart-actions {
      flex-direction: column;
    }
  }
</style>
